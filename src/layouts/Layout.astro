}

@media (max-width: 768px) {
    .mako-sub-header {
        display: flex;
        width: 100%;
        background: rgba(7, 11, 15, 0.85); /* Чуть плотнее, чтобы на мобилках контент не просвечивал */
        border-top: 1px solid rgba(0, 240, 255, 0.08);
        border-bottom: 1px solid rgba(0, 240, 255, 0.25);
    
        position: absolute;
        bottom: 0;
        left: 0;
        padding: 10px 0; 
    }

    .mako-sub-container {
        justify-content: center; 
        width: 100%;
   
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
    }

    /* Скрываем громоздкий текст (почту и телефон), так как они не влезут по ширине */
    .mako-sub-contacts {
        display: none;
    }

    /* Увеличиваем размер иконок соцсетей, чтобы по ним было удобно тапать на телефоне */
    .mako-sub-socials {
        gap: 24px; /* Увеличиваем расстояние между ними */
    }

    .mako-sub-social-item svg {
        width: 20px; 
        height: 20px;
        color: rgba(0, 240, 255, 0.85); /* На мобилке сразу даем им красивый неоновый тон */
    }
    .mako-sub-social-item {
        display: inline-flex; 

        color: #00F0FF;
        filter: drop-shadow(0 0 6px rgba(0, 240, 255, 0.7));
    }
}
.nav-container {
        width: 100%;
        height: auto;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
