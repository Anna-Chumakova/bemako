---
import Logo from '../components/Logo.astro';
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
	</head>
	<body>
	<header>
		<nav>
			<a href="/" class="logo-link">
				<Logo />
				<span class="brand-name">be<span>mako</span></span>
			</a>
		</nav>
	</header>

	<slot />
</body>
</html>

<style>
	
	:root {
	/* Цвета Be Mako */
	--mako-bg: #0B1117;
	--mako-cyan: #00F0FF;
	--mako-deep: #0088A9;
	--mako-text: #B0B8C1;
}

html {
	font-family: 'Inter', system-ui, sans-serif; /* Позже подключим Inter */
	background: var(--mako-bg);
	color: var(--mako-text);
}

body {
	margin: 0;
	width: 100%;
	height: 100%;
}

h1, h2, h3 {
	color: var(--mako-cyan);
}
header {
  padding: 1.5rem 2rem;
  display: flex;
  justify-content: center;
}

.logo-link {
  display: flex;
  align-items: center;
  gap: 1rem;
  text-decoration: none;
  color: white;
  font-weight: 700;
  font-size: 1.5rem;
  letter-spacing: -1px;
}

.brand-name span {
  color: var(--mako-cyan);
}
</style>
