---
import Logo from '../components/Logo.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
    title?: string;
    description?: string;
}

const { 
    title = "Be Mako | Technical SEO & Data Automation",
    description = "Technical SEO Engineering & Advanced Data Automation Studio. Scaling organic visibility via code, Node.js pipelines, and AI-driven infrastructure."
} = Astro.props;

// Автоматически формируем чистый канонический URL текущей страницы
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://be-mako.com'); 

---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        
        <title>{title}</title>
        <meta name="description" content={description} />
        
        <link rel="canonical" href={canonicalURL} />
        
        <ClientRouter />
    </head>
    <body>
        <header class="main-header">
            <nav class="nav-container">
                <a href="/" class="logo-link" aria-label="Be Mako Home">
                    <div class="logo-wrapper" transition:persist>
                        <Logo />
                    </div>
                </a>

                <button 
                  class="mobile-menu-toggle" 
                  aria-label="Открыть меню" 
                  style="position: relative; z-index: 9999; cursor: pointer;"
                >
                    <span class="bar"></span>
                    <span class="bar"></span>
                    <span class="bar"></span>
                </button>

                <div class="nav-links">
                    <a href="/#work">Work</a>
                    <a href="/#services">Services</a>
                    <a href="/#contact">Contact</a>
                </div>
            </nav>
        </header>

        <main class="page-content">
            <slot />
        </main>

        <footer class="main-footer">
            <p>&copy; {new Date().getFullYear()} be<span>mako</span>. Digital Predator.</p>
        </footer>

        <script>
    const setupNavigation = () => {
        const btn = document.querySelector('.mobile-menu-toggle');
        const menu = document.querySelector('.nav-links');
        const links = document.querySelectorAll('.nav-links a');

        // Если кнопки или меню нет на текущей странице, прерываем выполнение
        if (!btn || !menu) return;

        // Важно: явно указываем, что родительский элемент — это HTMLElement
        const parent = btn.parentNode as HTMLElement;
        if (!parent) return;

        // Очищаем старые слушатели клика (важно для Astro View Transitions)
        const newBtn = btn.cloneNode(true) as HTMLElement; // Приводим к HTMLElement
        parent.replaceChild(newBtn, btn);

        // Функция закрытия меню
        const closeMenu = () => {
            newBtn.classList.remove('is-active');
            menu.classList.remove('is-active');
            newBtn.setAttribute('aria-expanded', 'false');
            document.body.style.overflow = '';
        };

        // Логика кнопки-бургера
        newBtn.addEventListener('click', () => {
            const isOpened = newBtn.classList.toggle('is-active');
            menu.classList.toggle('is-active');
            newBtn.setAttribute('aria-expanded', isOpened.toString());
            document.body.style.overflow = isOpened ? 'hidden' : '';
        });

        // ЛОГИКА ДЛЯ ССЫЛОК: закрываем при каждом клике
        links.forEach(link => {
            link.addEventListener('click', () => {
                console.log("Клик по ссылке: меню закрывается");
                closeMenu();
            });
        });
    };

    // Инициализация
    setupNavigation();
    document.addEventListener('astro:page-load', setupNavigation);
</script>
    </body>
</html>

<style is:global>
    :root {
        --mako-bg: #0B1117;
        --mako-cyan: #00F0FF;
        --mako-text: #B0B8C1;
        --max-width: 1200px;
        --header-height: 170px;
        --section-gap: clamp(4rem, 10vw, 8rem);
    }

    .project-card-link,
.service-card-link {
    text-decoration: none !important;
    color: inherit !important;
    display: block;
}

/* Тотальный запрет на подчеркивание любого текста внутри этих ссылок */
.project-card-link *,
.service-card-link * {
    text-decoration: none !important;
}

    * { box-sizing: border-box; }

    html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        background: var(--mako-bg);
        color: var(--mako-text);
        font-family: 'Inter', system-ui, sans-serif;
        scroll-behavior: smooth;
        overflow-x: hidden;
    }
</style>

<style>
    .main-header {
        position: fixed;
        top: 0;
        width: 100%;
        height: var(--header-height);
        z-index: 1000;
        background: rgba(11, 17, 23, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(0, 240, 255, 0.1);
        display: flex;
        align-items: center;
        background-image: linear-gradient(
        to bottom,
        rgba(0, 240, 255, 0.12) 0%,   /* Насыщенный бирюзовый у самого верха */
        rgba(0, 180, 200, 0.05) 25%,  /* Плавный переход */
        rgba(11, 17, 23, 0) 60%       /* Полное растворение в темноте сайта к середине страницы */
    );
    
    /* Страховка, чтобы градиент не повторялся, если секция большая */
    background-repeat: no-repeat;
    }

    .nav-container {
        width: 100%;
        height: auto;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        color: #fff;
        font-weight: 800;
        font-size: 1.25rem;
    }

    .brand-name span { color: var(--mako-cyan); }

    .nav-links {
        display: flex;
        gap: 2.5rem;
    }

    .nav-links a {
        text-decoration: none;
        color: var(--mako-text);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        transition: 0.3s;
    }

    .nav-links a:hover { color: var(--mako-cyan); }

    .mobile-menu-toggle {
        display: none;
        flex-direction: column;
        gap: 6px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 10px;
        z-index: 1100;
    }

    .mobile-menu-toggle .bar {
        width: 28px;
        height: 2px;
        background-color: var(--mako-cyan);
        transition: 0.4s;
        border-radius: 2px;
    }

    @media (max-width: 768px) {
        .mobile-menu-toggle { display: flex; }

        .nav-links {
            position: fixed;
            top: 0;
            right: -100%;
            width: 100%;
            height: 100vh;
            background: var(--mako-bg);
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 3rem;
            transition: 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1050;
        }

        .nav-links.is-active { right: 0; }
        .nav-links a { font-size: 1.5rem; }

        /* Анимация иконок при активации */
        .mobile-menu-toggle.is-active .bar:nth-child(1) { transform: translateY(8px) rotate(45deg); }
        .mobile-menu-toggle.is-active .bar:nth-child(2) { opacity: 0; }
        .mobile-menu-toggle.is-active .bar:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
    }

    .page-content {
        width: 100%;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: calc(var(--header-height) + 2rem) 1.5rem 4rem;
    }

    .main-footer {
        text-align: center;
        padding: 4rem 1.5rem;
        border-top: 1px solid rgba(255,255,255,0.05);
        opacity: 0.6;
    }
</style>