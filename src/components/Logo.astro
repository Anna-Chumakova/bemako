<div class="logo-container">
  <!-- 1. ГРАФИКА: АКУЛА -->
  <div class="shark-box">
    <svg viewBox="0 0 92 69" class="shark-svg" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="1.5" result="blur" />
          <feComposite in="SourceGraphic" in2="blur" operator="over" />
        </filter>
      </defs>
      <g filter="url(#glow)">
        <!-- Тело акулы -->
        <path d="M28.9161 20.6596L1.41613 66.6596C17.2818 57.5051 26.8292 53.6178 45.4161 49.6596C45.7284 55.8223 44.1831 58.3043 40.4161 62.1596C49.1763 59.2479 53.2695 56.7786 57.9161 49.6596C67.7523 49.6061 72.4523 48.8245 78.9161 45.6596L72.9161 42.6596C76.8939 42.2057 79.294 42.4034 83.9161 43.6596L90.4161 38.6596C76.597 32.4111 68.3239 29.7798 51.4161 28.6596C45.1698 14.6978 39.6068 8.75824 26.4161 1.15959C29.6171 9.03147 30.2937 13.3159 28.9161 20.6596Z" fill="#0a1a1d" stroke="#00f3ff" stroke-width="1"/>
        <!-- Плавник -->
        <path d="M19.4161 52.6596L43.9161 44.1596L35.9161 25.6596L19.4161 52.6596Z" fill="#0a1a1d" stroke="#00f3ff" stroke-width="1"/>
        <!-- Буква С вокруг -->
        <path d="M89.9161 22.1596C75.8658 9.80557 67.1782 9.46583 50.4161 19.1596L54.9161 25.6596C65.9634 18.1509 72.3171 18.7052 83.9161 27.6596L89.9161 22.1596Z" fill="#0a1a1d" stroke="#00f3ff" stroke-width="1"/>
        <path d="M83.4161 52.6596C74.9102 60.1964 69.2103 60.7149 57.4161 55.1596L51.4161 60.6596C68.9247 69.9191 77.328 69.0384 89.9161 57.1596L83.4161 52.6596Z" fill="#0a1a1d" stroke="#00f3ff" stroke-width="1"/>
      </g>
    </svg>
  </div>
  <div class="brand-name-container">
    <span class="be">Be</span>
    <span class="ko">Mako</span>
    <div class="a-wrapper">
      <svg  viewBox="0 0 39 33" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M37.0166 1.08792C21.0966 9.16618 13.3034 16.1464 1.01665 32.0879H37.0166C26.8766 30.687 26.598 24.1935 37.0166 1.08792Z" fill="#00f3ff"/>
      </svg>
    </div> 
  </div>
</div>

<style>
.logo-container {
  display: flex;
  align-items: center; 
  justify-content: center;
  padding: 0; /* Убираем все внутренние отступы */
  position: relative;
  /* Даем небольшой запас сверху ВСЕМУ хедеру, чтобы акула не вылезала за пределы экрана */
  margin-top: 40px; 
}
@media (max-width: 768px){
  .logo-container {
    margin-top: 20px; 
  }
}
  

.shark-box {
  position: absolute;
  /* Акула позиционируется относительно текста brand-name-container */
  top: -59px; /* Сдвиг строго вверх. Регулируй этот параметр, чтобы поднять/опустить акулу */
  right: 13px; /* Сдвиг вправо. Регулируй, чтобы сместить ее ближе к букве 'o' или плавнику */
  width: 105px; 
  height: auto;
  /* z-index: 2; */
  pointer-events: none; /* Чтобы акула не перехватывала клики с текста */
} 

.shark-svg {
  width: 105px;
  height: auto;
  overflow: visible;
}

.brand-name-container {
  display: flex;
  align-items: center; 
  font-weight: 800;
  font-size: 48px; 
  line-height: 1;
  color: #00f3ff;
  position: relative;
  z-index: 1;
}

.be {
  color: white;
  margin-right: 0.15em;
}

.a-wrapper {
  display: inline-flex;
  align-items: center;
  width: 0.85em; 
  height: 0.7em; 
  position: relative;
  left: -3px;
  perspective: 1000px; 
}

.a-wrapper svg {
  position: absolute;
  bottom: -0.05em; 
  width: 110%;
  height: 110%;
  filter: drop-shadow(0 0 8px rgba(0, 243, 255, 0.5));
  transform-origin: bottom center;
  transform-style: preserve-3d;
  animation: infinity-tilt 5s ease-in-out infinite;
}

/* Анимации */
path {
  animation: simple-pulse 4s infinite ease-in-out;
}

@keyframes simple-pulse {
  0%, 100% { opacity: 1; filter: drop-shadow(0 0 2px rgba(0,240,255,0.2)); }
  50% { opacity: 0.9; filter: drop-shadow(0 0 5px rgba(0,240,255,0.5)); }
}

@keyframes infinity-tilt {
  0%, 100% { transform: rotateY(-10deg) rotateZ(-3deg) rotateX(0deg); }
  25% { transform: rotateY(15deg) rotateZ(5deg) rotateX(5deg); }
  50% { transform: rotateY(0deg) rotateZ(-5deg) rotateX(-5deg); }
  75% { transform: rotateY(-15deg) rotateZ(3deg) rotateX(5deg); }
}
</style>

