---
// Импортируем наш массив с данными проектов
import { projects } from '../data/projects.js';
---

<section id="work" class="portfolio-section">
    <h2 class="section-title">Featured Case Studies</h2>
    
    <div class="projects-grid">
        {projects.map((project) => (
            /* Оборачиваем карточку в ссылку на внутреннюю страницу */
            <a href={`/work/${project.slug}`} class="project-card-link">
                <div class="project-card">
                    <div class="card-badge">{project.badge}</div>
                    <h3>{project.title}</h3>
                    <p>{project.shortDesc}</p>
                    <div class="read-more">
                        Read Case Study 
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </div>
                </div>
            </a>
        ))}
    </div>
</section>

<style>
    .portfolio-section {
        padding: var(--section-gap) 0 2rem;
    }
    .section-title {
        font-size: 1.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #fff;
        margin-bottom: 3rem;
        position: relative;
        display: inline-block;
    }
    .section-title::after {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 0;
        width: 40px;
        height: 2px;
        background: var(--mako-cyan);
    }
    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        text-align: left;
    }
    
    /* Стили для ссылки-обертки */
    .project-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .project-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 2.5rem 2rem;
        border-radius: 4px;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
        height: 100%; /* Чтобы все карточки были одной высоты */
        display: flex;
        flex-direction: column;
    }
    
    /* Эффект ховера теперь срабатывает при наведении на ссылку */
    .project-card-link:hover .project-card {
        transform: translateY(-5px);
        background: rgba(0, 240, 255, 0.01);
        border-color: rgba(0, 240, 255, 0.2);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }
    
    .card-badge {
        display: inline-block;
        font-family: monospace;
        font-size: 0.75rem;
        color: var(--mako-cyan);
        border: 1px solid rgba(0, 240, 255, 0.3);
        padding: 0.25rem 0.75rem;
        border-radius: 2px;
        margin-bottom: 1.5rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        width: fit-content;
    }
    .project-card h3 {
        color: #fff;
        font-size: 1.25rem;
        margin: 0 0 1rem;
        line-height: 1.4;
    }
    .project-card p {
        font-size: 0.95rem;
        line-height: 1.6;
        margin: 0 0 1.5rem;
        color: var(--mako-text);
        flex-grow: 1; /* Подталкивает кнопку "Read More" вниз */
    }

    /* Стрелочка "Подробнее" */
    .read-more {
        font-family: monospace;
        font-size: 0.85rem;
        color: var(--mako-cyan);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: auto;
        transition: gap 0.2s ease;
    }
    .project-card-link:hover .read-more {
        gap: 0.8rem;
    }
</style>