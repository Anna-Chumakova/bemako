---
/* Компонент текстового логотипа с кастомной "а" */
---
<div class="brand-name-container">
  <span class="be">Be</span>

<!-- <span class="m">M</span> -->

 

<span class="ko">Mako</span>
<div class="a-wrapper">
    
    <!-- <svg  viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M67 98.9618H99L76 54.9618L1.5 98.9618H55L64 77.4618L67 98.9618Z" fill="#00f3ff"/>
