</svg>


</div> 

</div>

<style>
  .brand-name-container {
    display: inline-flex;
    align-items: baseline; /* Выравнивание по линии шрифта */
    /* font-family: monospace; Или твой основной шрифт */
    font-weight: 800;
    font-size: 48px; /* Регулируй размер здесь */
    line-height: 1;
    color: #00f3ff;
  }

  .be {
    /* color: var(--mako-text); */
    color: white;
    margin-right: 0.15em;
  }

  .a-wrapper {
    display: inline-block;
    width: 0.85em; /* Ограничиваем ширину буквы */
    height: 0.7em; /* Ограничиваем высоту до строчной буквы */
    /* margin: 0 0.02em; */
    

    position: relative;
    left: -3px;
    /* Создаем 3D пространство (чем меньше число, тем сильнее эффект) */
    perspective: 1000px; 
    display: inline-flex;
    align-items: center;
  }

  .a-wrapper svg {
    position: absolute;
    bottom: -0.05em; /* Чуть опускаем, чтобы "с... */
    
    width: 110%;
    height: 110%;
    filter: drop-shadow(0 0 8px rgba(0, 243, 255, 0.5));
   /* Фиксируем основание плавника, чтобы он "раскачивался" от корня */
    transform-origin: bottom center;
    transform-style: preserve-3d;
    
    /* 6 секунд — оптимально, чтобы движение не было суетливым */
    animation: infinity-tilt 5s ease-in-out infinite;
   
  }
    @keyframes infinity-tilt {
    0%, 100% {
      /* Исходное положение: чуть наклонен назад и вбок */
      transform: rotateY(-10deg) rotateZ(-3deg) rotateX(0deg);
    }
    
    25% {
      /* Плавник плавно разворачивается ребром к нам и наклоняется в одну сторону */
      transform: rotateY(15deg) rotateZ(5deg) rotateX(5deg);
    }

    50% {
      /* Проходим через центр с небольшим отклонением */
      transform: rotateY(0deg) rotateZ(-5deg) rotateX(-5deg);
    }

    75% {
      /* Разворот в другую сторону */
      transform: rotateY(-15deg) rotateZ(3deg) rotateX(5deg);
    }
  }
</style>