---
// 1. Импортируем встроенный компонент оптимизации изображений Astro
import { Image } from 'astro:assets';

// 2. Импортируем твой файл фотографии локально
import profilePhoto from '../assets/my-photo2.jpg'; // Укажи свое точное имя файла и расширение

---

<!-- JSON-LD Схема для поисковых роботов -->
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Аня",
    "alternateName": "Anya SEO",
    "jobTitle": "Data-Driven Technical SEO Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "Be Mako Studio",
      "url": "https://be-mako.com" 
    },
    "description": "Технический SEO-инженер и основатель студии Be Mako. Специализируюсь на автоматизации процессов на Node.js, AI-интеграциях и enterprise-миграциях сайтов на стек Astro.",
    "url": "https://be-mako.com",
    "knowsAbout": [
      "Technical SEO",
      "Search Engine Optimization",
      "Astro Framework",
      "Node.js Automation",
      "AI Engineering",
      "Programmatic SEO",
      "Core Web Vitals Optimization"
    ],
    "alumniOf": [
      {
        "@type": "EducationalOrganization",
        "name": "Название университета или платформы, где училась"
      }
    ],
    "hasCredential": [
      {
        "@type": "EducationalOccupationalCredential",
        "name": "Название твоего главного диплома/сертификата",
        "credentialCategory": "Certification"
      }
    ],
    "sameAs": [
      "https://github.com/твой-гитхаб",
      "https://linkedin.com/in/твой-линкендин",
      "https://t.me/твой-телеграм"
    ]
  }
</script>

<section id="about" class="about-section">
     <div class="code-accent">// WHO I AM</div>
    <div class="about-grid">
       
        <!-- Текстовая колонка -->
        <div class="about-content">
            
            <h2>Data-Driven Technical SEO Engineer</h2>
            <p>
                Hi, I'm Anya. I bridge the gap between heavy automation, clean code architectures, and aggressive organic growth. 
                While traditional SEOs rely only on third-party platforms, I build custom automated pipelines using <strong>Node.js</strong> and <strong>AI</strong> models like Gemini to capture scale that others cannot reach.
            </p>
            <p>
                Whether it’s executing a zero-traffic-loss enterprise migration to modern frameworks like <strong>Astro</strong> or launching global programmatic SEO infrastructure from scratch, my goal is simple: engineering maximum search visibility at peak technical performance.
            </p>
        </div>

        <!-- Колонка с фото -->
        
        <div class="about-image-wrapper">
            
            <div class="image-frame">
                <Image 
                    src={profilePhoto} 
                    alt="Anya — Technical SEO Engineer and Founder of Be Mako Studio" 
                    width={380}
                    height={380}
                    loading="eager" 
                    class="profile-img"
                    
                />
            </div>
        </div>

    </div>
</section>

<style>
    .about-section {
        padding: var(--section-gap) 0 2rem;
    }
    .about-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 3rem;
        align-items: center;
    }
    
    @media (max-width: 768px) {
        .about-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        .about-image-wrapper {
            margin-top: 1rem;
        }
    }

    .code-accent {
        font-family: monospace;
        color: var(--mako-cyan);
        letter-spacing: 2px;
        font-size: 0.85rem;
        margin-bottom: 1rem;
    }
    h2 {
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        color: #fff;
        margin: 0 0 1.5rem;
        font-weight: 800;
    }
    p {
        font-size: clamp(0.95rem, 1.5vw, 1.05rem);
        line-height: 1.7;
        color: var(--mako-text);
        margin-bottom: 1.5rem;
    }
    strong {
        color: #fff;
        font-weight: 600;
    }

   
    .about-image-wrapper {
        display: flex;
        justify-content: center;
        width: 100%;
    }
    
    .image-frame {
        position: relative;
        border: 1px solid rgba(0, 240, 255, 0.2);
        padding: 10px;
        background: rgba(255, 255, 255, 0.01);
        border-radius: 4px;
        
        /* Жестко резервируем место на экране до загрузки картинки */
        width: 100%;
        max-width: 400px; /* 380px картинка + 20px суммарный padding */
        aspect-ratio: 1 / 1; /* Браузер сразу поймет, что блок квадратный */
        box-sizing: border-box;
    }
    
    .image-frame::before {
        content: '';
        position: absolute;
        top: -1px;
        left: -1px;
        width: 20px;
        height: 20px;
        border-top: 2px solid var(--mako-cyan);
        border-left: 2px solid var(--mako-cyan);
    }
    
    .profile-img {
        display: block;
        width: 100%;
        height: 100%; /* Занимает всю внутреннюю область фрейма */
        max-width: 380px;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        border-radius: 2px;
        filter: grayscale(20%) contrast(110%);
        transition: filter 0.3s ease;
    }
    
    .image-frame:hover .profile-img {
        filter: grayscale(0%) contrast(100%);
    }
    @media (max-width: 992px) {
    .about-grid {
        grid-template-columns: 1fr;
        gap: 2.5rem;
    }
    
    /* Меняем визуальный порядок элементов через order */
    .about-image-wrapper {
        order: 1;      /* Картинка встает на первое место сверху */
        margin-top: 0; /* Сбрасываем верхний маргин, теперь он не нужен */
    }
    
    .about-content {
        order: 2;      /* Текст уходит под картинку */
    }
}
</style>