---
import Layout from '../layouts/Layout.astro';
import About from '../components/About.astro';
import Work from '../components/Work.astro';
import Services from '../components/Services.astro';
import Contact from '../components/Contact.astro';
---

<Layout title="Be Mako | Technical SEO & Data Automation">
    <div class="home-container">
        
        <section class="hero">
            <h1 class="title">Anna <span class="text-gradient">Chumakova</span><br>
            <span class="tagline">SEO SERVICES // WEB MASTER</span>
            </h1>
             
        </section>

        <About />
        <Work />
        <Services />
        <Contact />

    </div> 
</Layout>

<style>
    .home-container {
        width: 100%;
    }
    .hero {
        text-align: center;
        padding: 4rem 0 4rem;
    }
    .title {
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        margin: 0 0 1rem;
        color: #fff;
        font-weight: 800;
    }
    .text-gradient {
        color: var(--mako-cyan);
        text-shadow: 0 0 30px rgba(0, 240, 255, 0.3);
    }
    .tagline {
        font-family: monospace;
        letter-spacing: 2px;
        opacity: 0.8;
        font-size: clamp(0.9rem, 2vw, 1.1rem);
        margin: 0;
    }
</style>