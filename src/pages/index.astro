<style>
    /* Контейнер для выравнивания */
.hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 900px; /* Чтобы текст не растягивался во всю ширину экрана и легко читался */
    margin: 0 auto;
}

/* Стилизация кнопки */
.mako-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.5rem;
    margin-top: 2.5rem;
    color: #0B1117; /* Темный текст на неоновом фоне смотрится максимально контрастно и дорого */
    background: #00F0FF;
    font-size: 0.9rem;
    letter-spacing: 2px;
    text-decoration: none !important;
    text-transform: uppercase;
    font-weight: 700;
    border-radius: 4px;
    border: 1px solid #00F0FF;
    overflow: hidden;
    transition: all 0.3s ease;
    
    /* Базовый неоновый теневой шлейф */
    box-shadow: 0 0 15px rgba(0, 240, 255, 0.35), 
                0 0 30px rgba(0, 240, 255, 0.1);
}

/* Текст кнопки приподнимаем над эффектами */
.mako-btn span:not(.btn-glow) {
    position: relative;
    z-index: 2;
}

/* Внутреннее свечение (блик при наведении) */
.mako-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
        90deg,
        transparent,
        rgba(255, 255, 255, 0.4),
        transparent
    );
    transition: 0.5s;
    z-index: 1;
}

/* Эффект при наведении (Hover) */
.mako-btn:hover {
    color: #fff;
    background: transparent; /* Переключаемся на контурный неон */
    box-shadow: 0 0 20px rgba(0, 240, 255, 0.6), 
                0 0 40px rgba(0, 240, 255, 0.3),
                inset 0 0 15px rgba(0, 240, 255, 0.4);
    text-shadow: 0 0 5px rgba(0, 240, 255, 0.5);
}

.mako-btn:hover::before {
    left: 100%;
}

/* Активное состояние (клик) */
.mako-btn:active {
    transform: scale(0.98);
    box-shadow: 0 0 10px rgba(0, 240, 255, 0.5);
}
</style>